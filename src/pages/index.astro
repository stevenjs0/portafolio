---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import { getGitHubProfile } from '@utils/github';
import { SITE } from '@utils/site';
import { SITE_STATS } from '@utils/stats';
import { getPageContent } from '@utils/pages';
import { getFeaturedProjects } from '@utils/projects';
import { getLatestPosts } from '@utils/blog';
import { urlFor } from '@utils/sanity';

const profile = await getGitHubProfile();
const pageContent = await getPageContent('home');
const featuredProjects = await getFeaturedProjects(3);
const featuredPosts = await getLatestPosts(2);
---

<Layout>
  <Hero githubFollowers={profile?.followers} githubRepos={profile?.public_repos} />

  <section class="section-padding-fluid bg-background-elevated/30 px-4 md:px-6">
    <div class="container-narrow">
      <div class="section-header reveal">
        <div class="accent-line"></div>
        <h2>{pageContent?.sectionHeadingFeaturedProjects ?? 'Featured Projects'}</h2>
        <p>
          {pageContent?.sectionDescFeaturedProjects ?? 'A selection of recent work that showcases problem-solving abilities and technical expertise.'}
        </p>
      </div>

      <div class="grid-auto-fill-md reveal grid gap-6">
        {
          featuredProjects.map((project) => (
            <a href={`/projects/${project.slug.current}`} class="card group block overflow-hidden">
              <div class="bg-surface aspect-video overflow-hidden">
                <img
                  src={project.coverImage ? urlFor(project.coverImage).width(800).url() : '/fallback-project.svg'}
                  alt={project.title}
                  class="object-center-top h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  data-fallback="/fallback-project.svg"
                />
              </div>

              <div class="p-6">
                <h3 class="group-hover:text-accent mb-2 text-lg font-bold transition-colors">
                  {project.title}
                </h3>
                <p class="text-foreground-secondary mb-4 line-clamp-2 text-sm">
                  {project.summary}
                </p>

                <div class="flex flex-wrap gap-1.5">
                  {project.technologies.slice(0, 3).map((tech) => (
                    <span class="badge">{tech}</span>
                  ))}
                  {project.technologies.length > 3 && (
                    <span class="badge">+{project.technologies.length - 3}</span>
                  )}
                </div>
              </div>
            </a>
          ))
        }
      </div>


      <div class="reveal mt-24 mb-8 text-center">
        <a href="/projects" class="btn btn-secondary">
          {pageContent?.ctaViewAllProjects ?? 'View All Projects'}
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding-fluid px-4 md:px-6">
    <div class="container-narrow">
      <div class="grid-auto-fit-sm reveal grid gap-6">
        <div class="card p-6 text-center">
          <div class="text-accent mb-2 text-3xl font-bold md:text-4xl">{SITE_STATS.yearsExperience}</div>
          <div class="text-foreground-secondary text-sm">{pageContent?.statsYearsExperience ?? 'Years Experience'}</div>
        </div>
        <div class="card p-6 text-center">
          <div class="text-accent mb-2 text-3xl font-bold md:text-4xl">
            {profile?.public_repos ?? SITE_STATS.projectsBuilt}
          </div>
          <div class="text-foreground-secondary text-sm">{pageContent?.statsProjectsBuilt ?? 'Projects Built'}</div>
        </div>
        <div class="card p-6 text-center">
          <div class="text-accent mb-2 text-3xl font-bold md:text-4xl">
            {profile?.followers ?? SITE_STATS.githubFollowers}
          </div>
          <div class="text-foreground-secondary text-sm">{pageContent?.statsGitHubFollowers ?? 'GitHub Followers'}</div>
        </div>
        <div class="card p-6 text-center">
          <div class="text-accent mb-2 text-3xl font-bold md:text-4xl">{SITE_STATS.clientsServed}</div>
          <div class="text-foreground-secondary text-sm">{pageContent?.statsClientsServed ?? 'Clients Served'}</div>
        </div>
      </div>
    </div>
  </section>

  {
    featuredPosts.length > 0 && (
      <section class="section-padding-fluid bg-background-elevated/30 px-4 md:px-6">
        <div class="container-narrow">
          <div class="section-header reveal">
            <div class="accent-line" />
            <h2>{pageContent?.sectionHeadingLatestWriting ?? 'Latest Writing'}</h2>
            <p>{pageContent?.sectionDescLatestWriting ?? 'Thoughts on software engineering, technology, and professional growth.'}</p>
          </div>

          <div class="reveal grid grid-cols-1 gap-6 md:grid-cols-2">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.slug.current}`} class="card group block p-6">
                <div class="mb-3 flex items-start justify-between gap-4">
                  <h3 class="group-hover:text-accent text-lg font-bold transition-colors">
                    {post.title}
                  </h3>
                  <svg
                    class="text-foreground-muted group-hover:text-accent h-5 w-5 shrink-0 transition-all group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                </div>
                <p class="text-foreground-secondary mb-4 line-clamp-2 text-sm">
                  {post.excerpt}
                </p>
                <div class="text-foreground-muted flex flex-wrap items-center gap-3 font-mono text-xs">
                  <time>
                    {new Date(post.publishedAt).toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                  </time>
                  {post.body && (
                    <>
                      <span>·</span>
                      <span>5 min read</span>
                    </>
                  )}
                </div>
              </a>
            ))}
          </div>


          <div class="reveal mt-16 text-center">
            <a href="/blog" class="btn btn-secondary">
              {pageContent?.ctaReadAllPosts ?? 'Read All Posts'}
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </section>
    )
  }

  <section class="section-padding-fluid px-4 md:px-6">
    <div class="container-narrow">
      <div class="card reveal glow-subtle p-8 text-center md:p-12">
        <h2 class="mb-4">{pageContent?.sectionHeadingLetsWorkTogether ?? "Let's Work Together"}</h2>
        <p class="text-foreground-secondary mx-auto mb-8 max-w-prose">
          {pageContent?.sectionDescLetsWorkTogether ?? "Have a project in mind or want to discuss how I can help your team? I'm always open to new opportunities and interesting conversations."}
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/contact" class="btn btn-primary">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {pageContent?.ctaContactMe ?? 'Contact Me'}
          </a>
          <a
            href={SITE.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            {pageContent?.ctaLinkedIn ?? 'LinkedIn'}
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

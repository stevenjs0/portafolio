---
import Layout from '@layouts/Layout.astro';
import { getProjectBySlug } from '@utils/projects';
import { urlFor } from '@utils/sanity';
import { PortableText } from 'astro-portabletext';

export const prerender = false;

const { slug } = Astro.params;
const project = await getProjectBySlug(slug as string);

if (!project) {
  return Astro.redirect('/404');
}
---

<Layout title={project.title} description={project.summary}>
  <article class="mt-22 py-20 md:mt-28">
    <div class="container-narrow">
      <a
        href="/projects"
        class="text-foreground-muted hover:text-foreground reveal group mb-10 inline-flex items-center gap-2 text-sm"
      >
        <svg
          class="h-4 w-4 transition-transform group-hover:-translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Projects
      </a>

      <div class="reveal mb-12">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          {project.category && <span class="badge">{project.category}</span>}
          {
            project.featured && (
              <span class="badge border-yellow-500/20 bg-yellow-500/10 text-yellow-500">
                ★ Featured
              </span>
            )
          }
          <time class="text-foreground-muted font-mono text-xs">
            {
              new Date(project.date).toLocaleDateString('en-US', {
                month: 'long',
                year: 'numeric',
              })
            }
          </time>
        </div>

        <h1 class="mb-4 text-3xl font-bold md:text-5xl">{project.title}</h1>
        <p class="text-foreground-secondary text-lg leading-relaxed">{project.summary}</p>
      </div>

      <div class="reveal mb-12">
        <div class="border-border/50 bg-surface overflow-hidden rounded-2xl border">
          <img
            src={project.coverImage ? urlFor(project.coverImage).width(1200).url() : '/fallback-project.svg'}
            alt={project.title}
            class="aspect-video w-full object-cover"
            loading="lazy"
            data-fallback="/fallback-project.svg"
          />
        </div>
      </div>

      <div class="space-y-10">
        {
          project.problem && (
            <section class="reveal">
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-red-500/20 bg-red-500/10">
                  <svg
                    class="h-4 w-4 text-red-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 8v4m0 4h.01" />
                  </svg>
                </div>
                <h2 class="text-xl font-bold">The Problem</h2>
              </div>
              <p class="text-foreground-secondary pl-11 leading-relaxed">{project.problem}</p>
            </section>
          )
        }

        {
          project.solution && (
            <section class="reveal">
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-emerald-500/20 bg-emerald-500/10">
                  <svg
                    class="h-4 w-4 text-emerald-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48 2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48 2.83-2.83" />
                  </svg>
                </div>
                <h2 class="text-xl font-bold">The Solution</h2>
              </div>
              <p class="text-foreground-secondary pl-11 leading-relaxed">{project.solution}</p>
            </section>
          )
        }

        {
          project.impact && (
            <section class="reveal">
              <div class="mb-6 flex items-center gap-3">
                <div class="bg-accent/10 border-accent/20 flex h-8 w-8 items-center justify-center rounded-lg border">
                  <svg
                    class="text-accent h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                  </svg>
                </div>
                <h2 class="text-xl font-bold">Impact & Results</h2>
              </div>
              <p class="text-foreground-secondary mb-6 leading-relaxed">{project.impact}</p>

              {project.metrics && project.metrics.length > 0 && (
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  {project.metrics.map((metric) => (
                    <div class="card border-l-accent border-l-2 p-4">
                      <p class="text-foreground text-sm font-semibold">{metric}</p>
                    </div>
                  ))}
                </div>
              )}
            </section>
          )
        }

        {
          project.role && (
            <section class="reveal">
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-blue-500/20 bg-blue-500/10">
                  <svg
                    class="h-4 w-4 text-blue-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                </div>
                <h2 class="text-xl font-bold">My Role</h2>
              </div>
              <p class="text-foreground-secondary pl-11 leading-relaxed">{project.role}</p>
            </section>
          )
        }

        {
          project.technologies && project.technologies.length > 0 && (
            <section class="reveal">
              <h2 class="mb-4 text-xl font-bold">Technologies Used</h2>
              <div class="flex flex-wrap gap-2">
                {project.technologies.map((tech) => (
                  <span class="border-border/50 bg-surface/50 text-foreground-secondary rounded-lg border px-3 py-1.5 font-mono text-sm">
                    {tech}
                  </span>
                ))}
              </div>
            </section>
          )
        }
      </div>

      {
        project.links && (
          <div class="border-border/50 reveal mt-10 flex flex-wrap gap-3 border-t pt-8">
            {project.links.demo && (
              <a
                href={project.links.demo}
                class="btn btn-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
                Live Demo
              </a>
            )}
            {project.links.github && (
              <a
                href={project.links.github}
                class="btn btn-secondary"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
                View Code
              </a>
            )}
          </div>
        )
      }

      {project.content && (
        <div class="border-border/50 prose reveal mt-10 max-w-none border-t pt-10">
          <PortableText value={project.content} />
        </div>
      )}
    </div>
  </article>
</Layout>

<style>
  /* Prose styles for markdown content */
  .prose {
    color: var(--color-foreground-secondary);
  }
  .prose h2,
  .prose h3,
  .prose h4 {
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .prose p {
    margin-bottom: 1.25rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose code {
    background: var(--color-surface);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .prose pre {
    background: var(--color-surface);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }
  .prose pre code {
    background: none;
    padding: 0;
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .prose strong {
    color: var(--color-foreground);
  }
</style>

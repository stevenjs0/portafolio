---
import Layout from '@layouts/Layout.astro';
import { getAllPosts, getPostBySlug } from '@utils/blog';
import { urlFor } from '@utils/sanity';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect('/404');
}
---

<Layout title={post.title} description={post.excerpt}>
  <article class="mt-22 py-20 md:mt-28">
    <div class="container-narrow">
      <a
        href="/blog"
        class="text-foreground-muted hover:text-foreground reveal group mb-10 inline-flex items-center gap-2 text-sm"
      >
        <svg
          class="h-4 w-4 transition-transform group-hover:-translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Blog
      </a>

      <div class="reveal mb-10">
        <div class="text-foreground-muted mb-4 flex flex-wrap items-center gap-3 font-mono text-sm">
          <time>
            {
              new Date(post.publishedAt).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })
            }
          </time>
          <span>·</span>
          <span>5 min read</span>
          {
            post.categories && post.categories.length > 0 && (
              <>
                <span>·</span>
                <div class="flex flex-wrap gap-2">
                  {post.categories.map((cat) => (
                    <span class="badge">{cat}</span>
                  ))}
                </div>
              </>
            )
          }
        </div>

        <h1 class="mb-4 text-3xl leading-tight font-bold md:text-5xl">
          {post.title}
        </h1>

        {
          post.excerpt && (
            <p class="text-foreground-secondary text-lg leading-relaxed">{post.excerpt}</p>
          )
        }

        <div class="border-border/50 mt-6 flex items-center gap-3 border-t pt-6">
          <div
            class="bg-accent/10 border-accent/20 flex h-10 w-10 items-center justify-center rounded-full border"
          >
            <span class="text-accent text-sm font-bold">ES</span>
          </div>
          <div>
            <div class="text-foreground text-sm font-semibold">Erick Steven Muñoz</div>
            <div class="text-foreground-muted text-xs">Software Engineer</div>
          </div>
        </div>
      </div>

      {
        post.coverImage && (
          <div class="reveal mb-10">
            <div class="border-border/50 bg-surface overflow-hidden rounded-2xl border">
              <img
                src={urlFor(post.coverImage).width(1200).url()}
                alt={post.title}
                class="aspect-video w-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        )
      }

      <div class="prose reveal max-w-none">
        <PortableText value={post.body} />
      </div>

      <div class="border-border/50 reveal mt-12 border-t pt-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h3 class="text-foreground text-sm font-semibold">Share this post</h3>
          <div class="flex items-center gap-3">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border/50 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/30 inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm transition-all"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              Twitter
            </a>

            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border/50 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/30 inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm transition-all"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  /* Prose styles for markdown content */
  .prose {
    color: var(--color-foreground-secondary);
    font-size: 1.125rem;
    line-height: 1.75;
  }

  .prose h2,
  .prose h3,
  .prose h4 {
    color: var(--color-foreground);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
  }

  .prose h2 {
    font-size: 1.875rem;
  }

  .prose h3 {
    font-size: 1.5rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose code {
    background: var(--color-surface);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  .prose pre {
    background: var(--color-surface);
    padding: 1.25rem;
    border-radius: 12px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .prose strong {
    color: var(--color-foreground);
    font-weight: 600;
  }

  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-foreground-secondary);
  }

  .prose img {
    border-radius: 12px;
    border: 1px solid var(--color-border);
    margin: 2rem auto;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose th,
  .prose td {
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .prose th {
    background: var(--color-surface);
    font-weight: 600;
  }
</style>

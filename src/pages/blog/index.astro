---
import Layout from '@layouts/Layout.astro';
import { getAllPosts } from '@utils/blog';

const sortedPosts = await getAllPosts();
---

<Layout title="Blog" description="Thoughts on software engineering and lessons learned">
  <section class="section-padding-fluid mt-8 md:mt-12">
    <div class="container-narrow">
      <div class="section-header reveal">
        <div class="accent-line" />
        <h1>Blog</h1>
        <p>Thoughts on software engineering, technical deep-dives, and lessons learned from real projects.</p>
      </div>

      <div class="reveal rounded-xl overflow-hidden border border-border/50 divide-y divide-border/50">
        {sortedPosts.map((post) => {
          return (
            <article class="border-b border-border/50 last:border-b-0">
              <a
                href={`/blog/${post.slug.current}`}
                class="group block p-6 md:p-8 glow-subtle hover:bg-surface/30 transition-colors"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-3 mb-3 text-sm text-foreground-muted font-mono">
                      <time>
                        {new Date(post.publishedAt).toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric'
                        })}
                      </time>
                      <span>·</span>
                      <span>5 min read</span>
                      {post.categories && post.categories.length > 0 && (
                        <>
                          <span>·</span>
                          <div class="flex flex-wrap gap-2">
                            {post.categories.map((cat) => (
                              <span class="badge">{cat}</span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>

                    <h2 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-accent transition-colors">
                      {post.title}
                    </h2>

                    <p class="text-foreground-secondary text-sm md:text-base line-clamp-2">
                      {post.excerpt}
                    </p>
                  </div>

                  <div class="shrink-0">
                    <svg
                      class="w-5 h-5 text-foreground-muted group-hover:text-accent group-hover:translate-x-2 transition-all duration-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12h14"/>
                      <path d="m12 5 7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>


      {sortedPosts.length === 0 && (
        <div class="flex flex-col items-center justify-center py-20 text-foreground-muted reveal">
          <svg class="w-16 h-16 mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5Z"/>
          </svg>
          <p class="text-sm">No posts yet. Stay tuned!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

---
import Layout from '@layouts/Layout.astro';
import SkillsViz from '@react/SkillsViz';
import { getPageContent, parseSkillList } from '@utils/pages';
import { getAllSkills } from '@utils/skills';

const pageContent = await getPageContent('skills');
const softSkills = parseSkillList(pageContent?.skillsSoft ?? []);
const currentlyExploring = pageContent?.skillsCurrentlyExploring ?? [];

const skillCategories = await getAllSkills();
---

<Layout title="Skills" description="Technical skills and expertise">
  <section class="section-padding-fluid mt-8 md:mt-12">
    <div class="container-narrow">
      <div class="section-header reveal">
        <div class="accent-line"></div>
        <h1>Skills</h1>
        <p>My toolkit, organized by category. Select a category to see proficiency levels.</p>
      </div>

      <div class="reveal mb-16">
        <SkillsViz client:visible skillCategories={skillCategories} />
      </div>

      <div class="reveal mb-16 text-center">
        <h3 class="text-foreground-muted mb-6 text-xs font-bold tracking-widest uppercase">
          Currently Exploring
        </h3>
        <div class="flex flex-wrap justify-center gap-3">
          {
            currentlyExploring.map((tech) => (
              <span class="badge">{tech}</span>
            ))
          }
        </div>
      </div>

      <div class="reveal mt-16">
        <h3
          class="text-foreground-muted mb-10 text-center text-xs font-bold tracking-widest uppercase"
        >
          Beyond Code
        </h3>
        <div class="grid-auto-fill-md grid gap-6">
          {
            softSkills.map((skill) => (
              <div class="card p-5">
                <h4 class="mb-2 text-sm font-bold">{skill.title}</h4>
                <p class="text-foreground-muted text-sm leading-relaxed">{skill.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>


---
import { SITE } from '@utils/site';

const navLinks = [
  { href: '/about', label: 'About', icon: 'user' },
  { href: '/skills', label: 'Skills', icon: 'code' },
  { href: '/experience', label: 'Experience', icon: 'briefcase' },
  { href: '/projects', label: 'Projects', icon: 'folder' },
  { href: '/blog', label: 'Blog', icon: 'edit' },
  { href: '/contact', label: 'Contact', icon: 'mail' },
];

const currentPage = Astro.url.pathname;

function getIconSVG(iconName: string) {
  const icons: Record<string, string> = {
    user: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
    code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    briefcase: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
    folder: '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
    edit: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>',
    mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  };
  return icons[iconName] || '';
}
---

<header id="navbar" class="sticky top-0 z-sticky transition-all duration-300">
  <div class="nav-backdrop absolute inset-0 bg-linear-to-b from-background/90 via-background/70 to-transparent backdrop-blur-xl border-b border-border/30 transition-all duration-300" />

  <div class="relative py-4 md:py-5">
    <div class="container-wide">
      <div class="flex items-center justify-between h-16 md:h-20 px-4 md:px-6">

        <a href="/" class="group relative flex items-center gap-3 shrink-0">
          <div class="absolute inset-0 rounded-2xl bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" />
          <div class="relative w-10 h-10 rounded-2xl bg-linear-to-br from-accent/20 to-accent/5 border border-accent/30 flex items-center justify-center overflow-hidden group-hover:border-accent/50 group-hover:shadow-lg group-hover:shadow-accent/10 transition-all duration-300">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-accent group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-display text-base font-bold text-foreground leading-none tracking-tight group-hover:text-accent transition-colors duration-300">{SITE.alias}</span>
            <span class="text-xs text-foreground-muted font-mono leading-none mt-1 tracking-wide">Software Engineer</span>
          </div>
        </a>

        <nav class="hidden lg:flex items-center flex-1 justify-center" aria-label="Main navigation">
          <ul class="flex items-center gap-1 p-1.5 rounded-2xl bg-surface/60 border border-border/40 backdrop-blur-sm shadow-sm">
            {navLinks.map((link) => {
              const isActive = currentPage === link.href || (link.href !== '/' && currentPage.startsWith(link.href));
              return (
                <li>
                  <a
                    href={link.href}
                    aria-current={isActive ? "page" : undefined}
                    class="group/nav relative flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-xl transition-all duration-200"
                  >
                    {isActive && (
                      <span class="absolute inset-0 bg-accent rounded-xl shadow-md shadow-accent/20" />
                    )}

                    <span class="absolute inset-0 bg-accent/10 rounded-xl opacity-0 group-hover/nav:opacity-100 transition-opacity duration-200" />

                    <svg class={`relative w-4 h-4 transition-colors duration-200 ${isActive ? 'text-background' : 'text-foreground-muted group-hover/nav:text-accent'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={getIconSVG(link.icon)} />

                    <span class={`relative transition-colors duration-200 ${isActive ? 'text-background' : 'text-foreground-secondary group-hover/nav:text-foreground'}`}>
                      {link.label}
                    </span>

                    {!isActive && (
                      <span class="relative w-1 h-1 rounded-full bg-accent/0 group-hover/nav:bg-accent transition-all duration-200" />
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>

        <div class="flex items-center gap-2 shrink-0">
          <a href="/contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-background bg-accent rounded-xl hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/20 hover:-translate-y-0.5 transition-all duration-200">
            Let's Talk
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <button
            id="theme-toggle"
            class="group/theme relative flex items-center justify-center w-10 h-10 rounded-xl border border-border/40 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/40 hover:bg-accent/10 transition-all duration-200"
            aria-label="Toggle theme"
          >
            <div class="absolute inset-0 rounded-xl bg-accent/10 opacity-0 group-hover/theme:opacity-100 transition-opacity duration-200" />
            <svg id="icon-sun" class="relative w-4.5 h-4.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="5"/>
              <path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg id="icon-moon" class="relative w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>

          <button
            id="menu-btn"
            class="lg:hidden group/menu relative flex items-center justify-center w-10 h-10 rounded-xl border border-border/40 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/40 hover:bg-accent/10 transition-all duration-200"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <div class="absolute inset-0 rounded-xl bg-accent/10 opacity-0 group-hover/menu:opacity-100 transition-opacity duration-200" />
            <svg id="menu-icon" class="relative w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round">
              <path d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden overflow-hidden px-4 md:px-6">
        <nav class="bg-surface/95 border border-border/40 rounded-2xl p-4 mt-3 backdrop-blur-xl shadow-xl scrollbar-custom" aria-label="Mobile navigation">
          <ul class="flex flex-col gap-1 divide-y divide-border/30">
            {navLinks.map((link) => {
              const isActive = currentPage === link.href || (link.href !== '/' && currentPage.startsWith(link.href));
              return (
                <li>
                  <a
                    href={link.href}
                    aria-current={isActive ? "page" : undefined}
                    class="group/mobile relative flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200"
                  >
                    {isActive && (
                      <span class="absolute inset-0 bg-accent rounded-xl" />
                    )}

                    <span class="absolute inset-0 bg-accent/10 rounded-xl opacity-0 group-hover/mobile:opacity-100 transition-opacity duration-200" />

                    <svg class={`relative w-5 h-5 transition-colors duration-200 ${isActive ? 'text-background' : 'text-foreground-muted group-hover/mobile:text-accent'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={getIconSVG(link.icon)} />

                    <span class={`relative transition-colors duration-200 ${isActive ? 'text-background' : 'text-foreground-secondary group-hover/mobile:text-foreground'}`}>
                      {link.label}
                    </span>

                    {isActive && (
                      <span class="ml-auto w-2 h-2 rounded-full bg-background animate-pulse" />
                    )}
                  </a>
                </li>
              );
            })}
          </ul>

          <div class="mt-3 pt-3 border-t border-border/30">
            <a href="/contact" class="flex items-center justify-center gap-2 w-full px-4 py-3 text-sm font-semibold text-background bg-accent rounded-xl hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/20 transition-all duration-200">
              Let's Talk
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>

<div class="h-22 md:h-28" />

<script>
  const toggle = document.getElementById('theme-toggle');
  const menuBtn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const navbar = document.getElementById('navbar');

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  menuBtn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    const isOpen = !isHidden;
    menuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    // Toggle icon with animation
    if (menu && !menu.classList.contains('hidden')) {
      menuIcon!.innerHTML = '<path d="M18 6L6 18M6 6l12 12"/>';
    } else {
      menuIcon!.innerHTML = '<path d="M4 6h16M4 12h16M4 18h16"/>';
    }
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menuIcon!.innerHTML = '<path d="M4 6h16M4 12h16M4 18h16"/>';
      menuBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll-aware navbar
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    const navBackdrop = navbar?.querySelector('.nav-backdrop');

    if (currentScroll > 50) {
      navBackdrop?.classList.add('bg-background/95', 'shadow-lg', 'shadow-black/5');
      navBackdrop?.classList.remove('bg-gradient-to-b', 'from-background/90', 'via-background/70', 'to-transparent', 'border-border/30');
      navBackdrop?.classList.add('border-border/50');
    } else {
      navBackdrop?.classList.remove('bg-background/95', 'shadow-lg', 'shadow-black/5', 'border-border/50');
      navBackdrop?.classList.add('bg-gradient-to-b', 'from-background/90', 'via-background/70', 'to-transparent', 'border-border/30');
    }

  });

  // Close mobile menu on resize
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024 && menu) {
      menu.classList.add('hidden');
      menuIcon!.innerHTML = '<path d="M4 6h16M4 12h16M4 18h16"/>';
    }
  });
</script>

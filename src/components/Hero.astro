---
import { SITE } from '@utils/site';
import { getPageContent } from '@utils/pages';

const { githubFollowers, githubRepos } = Astro.props;
const firstName = SITE.name.split(' ').slice(0, 2).join(' ');
const pageContent = await getPageContent('hero');
---

<section class="relative flex min-h-screen snap-start flex-col justify-between overflow-hidden">
  <!-- Animated background -->
  <div class="bg-background pointer-events-none absolute inset-0" aria-hidden="true">
    <!-- Grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image:
        linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px);
        background-size: 4rem 4rem;"
    >
    </div>

    <!-- Gradient orbs with aspect-ratio -->
    <div
      class="bg-accent/5 animate-float absolute top-1/4 -left-1/4 aspect-square w-[33vw] rounded-full blur-3xl"
    >
    </div>
    <div
      class="bg-accent/3 animate-float absolute -right-1/4 bottom-1/4 aspect-square w-[25vw] rounded-full blur-3xl"
      style="animation-delay: 1.5s;"
    >
    </div>
  </div>

  <!-- Center content -->
  <div class="relative z-10 flex flex-1 items-center justify-center">
    <div class="container-narrow px-4 py-20 md:px-6 md:py-24 lg:py-28">
      <div class="flex flex-col items-center text-center">
        <!-- Status badge -->
        <div
          class="border-border/50 bg-surface/50 animate-fade-in-up mb-6 inline-flex items-center gap-2.5 rounded-full border px-4 py-2 backdrop-blur-sm md:mb-8"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
          </span>
          <span class="text-foreground-secondary text-sm font-medium"
            >{pageContent?.statusBadge ?? 'Available for new opportunities'}</span
          >
        </div>

        <!-- Main heading -->
        <h1 class="animate-fade-in-up stagger-1 mb-6">
          <span class="text-foreground font-body mb-4 block text-lg font-normal md:text-xl"
            >{pageContent?.greeting ?? "Hello, I'm"}</span
          >
          <span
            class="font-display block text-4xl leading-tight font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
          >
            <span class="text-foreground">{firstName.split(' ')[0]}</span>
            <span class="gradient-text ml-2">{firstName.split(' ')[1] || ''}</span>
          </span>
        </h1>

        <!-- Alias -->
        <p
          class="text-foreground-muted animate-fade-in-up stagger-2 mb-4 font-mono text-base md:mb-6 md:text-lg"
        >
          @{SITE.alias}
          <span class="text-foreground-secondary mx-2">·</span>
          {SITE.title}
        </p>

        <!-- Description -->
        <p
          class="text-foreground-secondary animate-fade-in-up stagger-3 mb-8 max-w-prose text-base leading-relaxed md:mb-10 md:text-lg"
        >
          {pageContent?.description ?? "From Ecuador · Building exceptional digital experiences for clients worldwide. 3+ years of turning ideas into production-ready software."}
        </p>

        <!-- CTAs - Using flex with space distribution -->
        <div
          class="animate-fade-in-up stagger-4 mb-10 flex flex-col items-center justify-center gap-3 sm:flex-row md:mb-12 md:gap-4"
        >
          <a href="/projects" class="btn btn-primary w-full min-w-40 sm:w-auto md:min-w-48">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
            </svg>
            {pageContent?.ctaPrimary ?? 'View Projects'}
          </a>
          <a href="/contact" class="btn btn-secondary w-full min-w-40 sm:w-auto md:min-w-48">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {pageContent?.ctaSecondary ?? 'Get In Touch'}
          </a>
        </div>

        <!-- Tech stack - Using auto-fit grid -->
        <div class="animate-fade-in-up stagger-5 w-full">
          <p class="text-foreground-muted mb-3 font-mono text-xs tracking-wider uppercase">
            Tech Stack
          </p>
          <div class="grid grid-cols-[repeat(auto-fit,minmax(min(100%,8rem),1fr))] gap-2">
            {
              (pageContent?.techStack?.length ? pageContent.techStack : ['React', 'TypeScript', 'Node.js', 'Java', 'Python', 'MongoDB', 'Angular', 'AWS']).map(
                (tech) => (
                  <span class="border-border/50 bg-surface/50 text-foreground-secondary hover:border-accent/30 hover:text-accent cursor-default rounded-lg border px-3 py-1.5 text-center font-mono text-sm transition-colors">
                    {tech}
                  </span>
                ),
              )
            }
          </div>
        </div>

        <!-- GitHub stats - Using flex with justify-center and gap -->
        {
          githubFollowers !== undefined && githubRepos !== undefined && (
            <div class="text-foreground-muted animate-fade-in-up stagger-6 mt-6 flex flex-wrap items-center justify-center gap-4 font-mono text-sm md:mt-8 md:gap-6">
              <a
                href={`https://github.com/${SITE.githubUsername}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-foreground inline-flex items-center gap-2 transition-colors"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
                {githubFollowers} followers
              </a>
              <a
                href={`https://github.com/${SITE.githubUsername}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-foreground inline-flex items-center gap-2 transition-colors"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M15 22v-4a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v4" />
                  <rect x="2" y="2" width="20" height="8" rx="2" />
                  <circle cx="12" cy="14" r="2" />
                  <path d="M12 18h.01" />
                </svg>
                {githubRepos} repos
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

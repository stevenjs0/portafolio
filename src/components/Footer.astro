---
import { SITE } from '@utils/site';
import { getPageContent } from '@utils/pages';

const pageContent = await getPageContent('footer');
const navLabels = pageContent?.navLabels?.length ? pageContent.navLabels : ['About', 'Projects', 'Blog', 'Contact'];
const footerLinks = [
  { href: '/about', label: navLabels[0] },
  { href: '/projects', label: navLabels[1] },
  { href: '/blog', label: navLabels[2] },
  { href: '/contact', label: navLabels[3] },
];
---

<footer class="border-border/50 relative border-t">
  <div class="container-wide">
    <!-- Main footer - Using CSS Grid for responsive three-section layout -->
    <div class="grid grid-cols-1 items-center gap-8 py-12 lg:grid-cols-[1fr_auto_1fr] lg:gap-12">
      <!-- Left: Logo & tagline -->
      <div class="flex flex-col items-center gap-4 text-center lg:items-start lg:text-left">
        <a href="/" class="group flex items-center gap-3 transition-opacity hover:opacity-80">
          <div
            class="bg-accent/10 border-accent/20 group-hover:border-accent/40 flex h-10 w-10 items-center justify-center rounded-xl border transition-colors"
          >
            <svg
              viewBox="0 0 24 24"
              class="text-accent h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <span class="font-display text-foreground text-base font-bold tracking-tight"
            >{SITE.alias}</span
          >
        </a>
        <p class="text-foreground-secondary max-w-xs text-sm">{pageContent?.footerTagline ?? SITE.description}</p>
      </div>

      <!-- Center: Links - Using flex with justify-evenly for equal spacing -->
      <nav
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2"
        aria-label="Footer navigation"
      >
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-foreground-secondary hover:text-foreground text-sm transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Right: Social links -->
      <div class="flex items-center justify-center gap-4 lg:justify-end">
        <!-- GitHub -->
        <a
          href={SITE.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="border-border/50 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/30 flex h-10 w-10 items-center justify-center rounded-xl border transition-all duration-200"
          aria-label="GitHub"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href={SITE.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="border-border/50 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/30 flex h-10 w-10 items-center justify-center rounded-xl border transition-all duration-200"
          aria-label="LinkedIn"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${SITE.email}`}
          class="border-border/50 bg-surface/50 text-foreground-secondary hover:text-foreground hover:border-accent/30 flex h-10 w-10 items-center justify-center rounded-xl border transition-all duration-200"
          aria-label="Email"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar - Using flex with justify-between -->
    <div
      class="border-border/30 flex flex-col items-center justify-between gap-4 border-t py-6 sm:flex-row"
    >
      <p class="text-foreground-muted font-mono text-xs">
        &copy; {new Date().getFullYear()}
        {SITE.name}. All rights reserved.
      </p>
      <p class="text-foreground-muted text-xs">
        Built with <a
          href="https://astro.build/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-accent transition-colors">Astro</a
        > & <a
          href="https://react.dev/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-accent transition-colors">React</a
        >
      </p>
    </div>
  </div>
</footer>

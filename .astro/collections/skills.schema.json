{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "order": {
      "default": 999,
      "type": "number"
    },
    "skills": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "level": {
            "type": "number"
          },
          "years": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "level",
          "years"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "icon"
  ]
}
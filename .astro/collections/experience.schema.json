{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "period": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "order": {
      "default": 999,
      "type": "number"
    },
    "achievements": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tech": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "period",
    "role",
    "company"
  ]
}